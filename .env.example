# Copy this file to .env and adjust as needed.
# `scripts/setup-ledger.sh` fills in the SEED/DID/secret values automatically.

# ACA-Py container image (pinned working tag, see README for why)
ACAPY_IMAGE=ghcr.io/openwallet-foundation/acapy-agent:1.6.0

# Public Indy test ledger used for schema/cred-def anchoring.
# Bifold and other Aries wallets ship with this ledger pre-configured, so no
# custom genesis file needs to be side-loaded onto the phone. See README.
GENESIS_URL=https://test.bcovrin.vonx.io/genesis
LEDGER_REGISTER_URL=https://test.bcovrin.vonx.io/register

# --- University (issuer + verifier) agent ---
# Filled in by scripts/setup-ledger.sh after registering a DID on the test ledger.
UNIVERSITY_SEED=
UNIVERSITY_DID=
UNIVERSITY_WALLET_KEY=change-me-university-wallet-key
# Where OTHER agents/wallets can reach this agent over DIDComm.
# For automated (phone-free) testing, the docker-network hostname works fine.
# For a USB-debugging phone, run: bash scripts/phone-usb-tunnel.sh
#   (sets both to http://127.0.0.1:8023 / ws://127.0.0.1:8023 via adb reverse)
# For Wi-Fi / remote phones, tunnel transport-proxy and set:
#   UNIVERSITY_ENDPOINT=https://<ngrok-host>
#   UNIVERSITY_WS_ENDPOINT=wss://<ngrok-host>
#   ngrok http 8023   # must be 8023 (transport-proxy), not 8020
UNIVERSITY_ENDPOINT=http://university-agent:8020
UNIVERSITY_WS_ENDPOINT=ws://university-agent:8022

# --- Student test-wallet agent (stands in for a phone wallet in automated tests) ---
STUDENT_WALLET_KEY=change-me-student-wallet-key

# --- Faculty test-wallet agent (the other side of the bonus DIDComm messaging demo) ---
FACULTY_WALLET_KEY=change-me-faculty-wallet-key

# --- Backend ---
BACKEND_PORT=5000
SESSION_SECRET=change-me-session-secret
ADMIN_TOKEN=change-me-admin-token
FRONTEND_ORIGIN=http://localhost:5173
